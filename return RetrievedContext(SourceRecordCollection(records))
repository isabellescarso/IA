from __future__ import annotations
from uuid import UUID, uuid4
from pydantic import BaseModel, Field, ConfigDict


class RagConfiguration(BaseModel):
    top_k: int = 4
    collection_name: str = "cgmacros_embeddings"
    rerank_enabled: bool = False



class GenerationConfiguration(BaseModel):
    temperature: float = 0.2
    maximum_tokens: int = 512
    top_p: float = 0.9


class RequestMetadata(BaseModel):
    user_identifier: str
    client_origin: str


class AskRequest(BaseModel):
    model_config = ConfigDict(populate_by_name=True)

    query: str = Field(alias="question")
    model: str = "llama3.2"
    conversation_identifier: str | None = None
    rag_configuration: RagConfiguration = RagConfiguration()
    generation_configuration: GenerationConfiguration = GenerationConfiguration()
    request_metadata: RequestMetadata | None = None


# ── Response value objects ────────────────────────────────────────

class TokenUsage(BaseModel):
    prompt_tokens: int
    completion_tokens: int
    total_tokens: int


class LatencyBreakdown(BaseModel):
    total_milliseconds: int
    retrieval_milliseconds: int
    generation_milliseconds: int

class RetrievalSource(BaseModel):
    chunk_identifier: str
    similarity_score: float

class RetrievalSourceCollection(BaseModel):
    sources: list[RetrievalSource]

    def highest_scoring(self) -> RetrievalSource | None:
        return max(self.sources, key=lambda source: source.similarity_score, default=None)


class RetrievalDetail(BaseModel):
    collection_name: str
    embedding_model_name: str
    sources: list[RetrievalSource]


class AskResponse(BaseModel):
    request_identifier: str = Field(default_factory=lambda: str(uuid4()))
    conversation_identifier: str
    model_used: str
    answer: str
    token_usage: TokenUsage
    latency_breakdown: LatencyBreakdown
    retrieval_detail: RetrievalDetail
